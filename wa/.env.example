# Backend WA — salin file ini ke .env lalu sesuaikan jika perlu.
# Di XAMPP/Windows, API UWABA biasanya di: http://localhost/api/public/api
#
# npm install gagal (Chrome Puppeteer: ZIP corrupt / folder cache tanpa chrome.exe): dari folder wa
#   npm run install:safe
# Opsional hapus cache rusak: folder %USERPROFILE%\.cache\puppeteer\chrome lalu install:safe lagi.
# Lalu npm run dev (Chrome dipakai saat runtime lewat whatsapp-web.js).

# URL dasar API UWABA (tanpa trailing slash). Dipakai untuk verifikasi token (GET .../auth/verify)
# dan webhook pesan masuk: setiap pesan WA yang diterima akan di-POST ke {URL}/api/wa/incoming (atau .../wa/incoming jika URL berakhiran /api).
# Wajib di-set agar balasan otomatis (mis. Daftar Notifikasi) jalan.
UWABA_API_BASE_URL=http://localhost/api/public/api

# Port server WA (default 3001). Error EADDRINUSE = port sudah dipakai: tutup npm run dev lain atau ubah PORT.
# Jika PORT bukan 3001: set juga di ebeddien/.env → VITE_WA_BACKEND_PORT=<port> (atau VITE_WA_BACKEND_URL) lalu restart Vite.
PORT=3001
# Opsional: paksa Chrome/Edge sistem (disarankan di Windows setelah npm run install:safe).
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Asal frontend untuk CORS (opsional). ebeddien/ebeddien2 sudah diizinkan di server.js.
# UWABA_ORIGIN=http://localhost:5173
# Ebeddien_ORIGIN=https://ebeddien2.alutsmani.id

# Kunci untuk auth kirim pesan dari PHP/server (header X-API-Key). Harus sama dengan WA_API_KEY di api/config atau .env API.
WA_API_KEY=rahasia-buat-php

# --- Di api/.env (PHP), bukan di file ini ---
# WA_SESSION_ID = ID slot WA yang TERHUBUNG (sama dengan dropdown "Kirim tes" / nama slot di Koneksi WA).
# Tanpa ini, PHP memakai session "default" di Node; kalau Anda hanya scan QR di slot lain, OTP/notifikasi bisa gagal (No LID)
# sementara "Kirim tes" dari UI berhasil. Contoh: WA_SESSION_ID=default  atau  WA_SESSION_ID=wa2
#
# Error "No LID for user" = WhatsApp Web (whatsapp-web.js) belum punya mapping kontak↔LID. Mitigasi:
# - Pastikan Langkah 2 (Baileys) terhubung untuk slot yang sama (kirim teks lewat Baileys dulu di server).
# - Di folder wa: npm update whatsapp-web.js (paket dari GitHub main — sering ada perbaikan getChat/LID).
