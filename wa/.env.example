# Backend WA — salin file ini ke .env lalu sesuaikan jika perlu.
# Di XAMPP/Windows, API UWABA biasanya di: http://localhost/api/public/api

# URL dasar API UWABA (tanpa trailing slash). Dipakai untuk verifikasi token (GET .../auth/verify).
UWABA_API_BASE_URL=http://localhost/api/public/api

# Port server WA (default 3001)
PORT=3001

# Asal frontend UWABA (opsional, untuk CORS). Contoh: http://localhost:5173
# UWABA_ORIGIN=http://localhost:5173

# Kunci untuk auth kirim pesan dari PHP/server (header X-API-Key). Harus sama dengan WA_API_KEY di api/config atau .env API.
WA_API_KEY=rahasia-buat-php
