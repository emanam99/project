# CORS untuk /gambar/ — agar ebeddien2, uwaba2, daftar2, dll. bisa fetch icon/gambar dari alutsmani.id/gambar/
# WAJIB: Letakkan file ini di folder yang dilayani sebagai https://alutsmani.id/gambar/ (biasanya public_html/gambar/)

<IfModule mod_headers.c>
    # Izinkan alutsmani.id + subdomain (ebeddien2, ebeddien, uwaba2, daftar, ...); echo Origin peminta
    SetEnvIf Origin "^https?://([a-z0-9.-]+\.)?alutsmani\.id$" CORS_ALLOWED=1
    SetEnvIf Origin "^https?://([a-z0-9.-]+\.)?alutsmani\.my\.id$" CORS_ALLOWED=1
    SetEnvIf Origin "^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$" CORS_ALLOWED=1
    Header always set Access-Control-Allow-Origin "%{HTTP_ORIGIN}e" env=CORS_ALLOWED
    Header always set Access-Control-Allow-Methods "GET, HEAD, OPTIONS" env=CORS_ALLOWED
    Header always set Access-Control-Allow-Credentials "true" env=CORS_ALLOWED
    Header always set Access-Control-Max-Age "86400" env=CORS_ALLOWED
    Header always set Vary "Origin" env=CORS_ALLOWED
</IfModule>

# Preflight OPTIONS: kembalikan 204 dan header CORS
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^ - [L]
</IfModule>
