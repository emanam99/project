# Konfigurasi Apache untuk absen.alutsmani.id
# File .htaccess untuk mengatur akses dan keamanan

# Enable mod_rewrite
RewriteEngine On

# Set index file priority (PHP only)
DirectoryIndex index.php

# Force HTTPS untuk subdomain
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# CORS headers untuk mesin BioFinger
Header always set Access-Control-Allow-Origin "*"
Header always set Access-Control-Allow-Methods "POST, GET, OPTIONS"
Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"

# Handle preflight OPTIONS requests
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Set default charset
AddDefaultCharset UTF-8

# Security headers
Header always set X-Content-Type-Options nosniff
Header always set X-Frame-Options DENY
Header always set X-XSS-Protection "1; mode=block"

# Allow access to PHP files
<Files "*.php">
    Order Allow,Deny
    Allow from all
</Files>

# Allow access to log files (untuk debugging)
<Files "*.log">
    Order Allow,Deny
    Allow from all
</Files>

# Allow access to CSV files
<Files "*.csv">
    Order Allow,Deny
    Allow from all
</Files>

# Block access to sensitive files
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|inc|bak)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Set PHP settings
php_value max_execution_time 30
php_value memory_limit 128M
php_value upload_max_filesize 10M
php_value post_max_size 10M

# Enable error logging
php_flag log_errors On
php_value error_log error.log

# Set timezone
php_value date.timezone "Asia/Jakarta"
