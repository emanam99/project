# Enable CORS untuk file uploads
<IfModule mod_headers.c>
    # Set CORS headers untuk semua file di folder uploads
    # Izinkan akses dari semua subdomain alutsmani.id dan localhost untuk development
    SetEnvIf Origin "^https?://(.*\.)?alutsmani\.id$" CORS=1
    SetEnvIf Origin "^https?://(.*\.)?localhost(:[0-9]+)?$" CORS=1
    SetEnvIf Origin "^https?://127\.0\.0\.1(:[0-9]+)?$" CORS=1
    
    # Set header CORS untuk semua request (termasuk gambar)
    Header always set Access-Control-Allow-Methods "GET, OPTIONS"
    Header always set Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization, Cache-Control"
    Header always set Access-Control-Allow-Credentials "true"
    Header always set Access-Control-Max-Age "3600"
    
    # Set Access-Control-Allow-Origin berdasarkan origin request
    Header always set Access-Control-Allow-Origin "%{HTTP_ORIGIN}e" env=CORS
    Header always set Access-Control-Allow-Origin "*" env=!CORS
</IfModule>

# Handle OPTIONS request untuk preflight
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]
</IfModule>
